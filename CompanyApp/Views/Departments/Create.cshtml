@model CompanyApp.Models.Department
@{ ViewData["Title"] = "New Department"; }

<h2 class="mb-4">🏬 New Department</h2>
<div class="card p-4" style="max-width:500px">
    <form asp-action="Create">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="mb-3">
            <label asp-for="DepartmentName" class="form-label fw-bold"></label>
            <input asp-for="DepartmentName" class="form-control" />
            <span asp-validation-for="DepartmentName" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="DepartmentLocation" class="form-label fw-bold"></label>
            <input asp-for="DepartmentLocation" class="form-control" />
            <span asp-validation-for="DepartmentLocation" class="text-danger"></span>
        </div>
        <div class="d-flex gap-2">
            <input type="submit" value="Create" class="btn btn-primary" />
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>
