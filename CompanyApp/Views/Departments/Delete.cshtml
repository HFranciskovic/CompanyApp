@model CompanyApp.Models.Department
@{ ViewData["Title"] = "Delete Department"; }

<h2 class="mb-4">🗑️ Delete Department</h2>
<div class="card p-4" style="max-width:500px">
    <div class="alert alert-danger">Are you sure you want to delete this department?</div>
    <dl class="row">
        <dt class="col-sm-4 fw-bold">No.</dt>
        <dd class="col-sm-8">@Model.DepartmentNo</dd>
        <dt class="col-sm-4 fw-bold">Name</dt>
        <dd class="col-sm-8">@Model.DepartmentName</dd>
        <dt class="col-sm-4 fw-bold">Location</dt>
        <dd class="col-sm-8">@Model.DepartmentLocation</dd>
    </dl>
    <form asp-action="Delete">
        <input type="hidden" asp-for="DepartmentNo" />
        <div class="d-flex gap-2 mt-3">
            <input type="submit" value="Delete" class="btn btn-danger" />
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>
