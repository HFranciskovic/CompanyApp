@model IEnumerable<CompanyApp.Models.Department>
@{ ViewData["Title"] = "Departments"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>🏬 Departments</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Department</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>No.</th>
                    <th>Name</th>
                    <th>Location</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.DepartmentNo</td>
                        <td>@item.DepartmentName</td>
                        <td>@item.DepartmentLocation</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.DepartmentNo" class="btn btn-sm btn-outline-info">Details</a>
                            <a asp-action="Edit" asp-route-id="@item.DepartmentNo" class="btn btn-sm btn-outline-warning">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.DepartmentNo" class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
