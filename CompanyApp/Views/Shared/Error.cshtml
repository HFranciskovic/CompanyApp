@model CompanyApp.Models.ErrorViewModel
@{ ViewData["Title"] = "Error"; }

<div class="text-center py-5">
    <h1 class="text-danger">⚠️ An error occurred.</h1>
    @if (Model.ShowRequestId)
    {
        <p>Request ID: <code>@Model.RequestId</code></p>
    }
    <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-3">Go Home</a>
</div>
