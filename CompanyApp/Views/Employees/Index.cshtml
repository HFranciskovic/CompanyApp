@model IEnumerable<CompanyApp.Models.Employee>
@{ ViewData["Title"] = "Employees"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>👥 Employees</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Employee</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>No.</th>
                    <th>Name</th>
                    <th>Salary</th>
                    <th>Department</th>
                    <th>Last Modified</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.EmployeeNo</td>
                        <td>@item.EmployeeName</td>
                        <td>@item.Salary.ToString("N0")</td>
                        <td>@item.Department?.DepartmentName</td>
                        <td>@item.LastModifyDate.ToString("dd.MM.yyyy")</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.EmployeeNo" class="btn btn-sm btn-outline-info">Details</a>
                            <a asp-action="Edit" asp-route-id="@item.EmployeeNo" class="btn btn-sm btn-outline-warning">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.EmployeeNo" class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
