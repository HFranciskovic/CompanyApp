@model CompanyApp.Models.Employee
@{ ViewData["Title"] = "Delete Employee"; }

<h2 class="mb-4">🗑️ Delete Employee</h2>
<div class="card p-4" style="max-width:500px">
    <div class="alert alert-danger">Are you sure you want to delete this employee?</div>
    <dl class="row">
        <dt class="col-sm-4 fw-bold">No.</dt>
        <dd class="col-sm-8">@Model.EmployeeNo</dd>
        <dt class="col-sm-4 fw-bold">Name</dt>
        <dd class="col-sm-8">@Model.EmployeeName</dd>
        <dt class="col-sm-4 fw-bold">Salary</dt>
        <dd class="col-sm-8">@Model.Salary.ToString("N0")</dd>
        <dt class="col-sm-4 fw-bold">Department</dt>
        <dd class="col-sm-8">@Model.Department?.DepartmentName</dd>
    </dl>
    <form asp-action="Delete">
        <input type="hidden" asp-for="EmployeeNo" />
        <div class="d-flex gap-2 mt-3">
            <input type="submit" value="Delete" class="btn btn-danger" />
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>
