@{
    ViewData["Title"] = "Home";
}

<div class="text-center py-5">
    <h1 class="display-4 fw-bold" style="color:#2c3e50">🏢 Company Management System</h1>
    <p class="lead text-muted mb-5">Manage your departments and employees easily.</p>
    <div class="row justify-content-center g-4">
        <div class="col-md-4">
            <div class="card p-4 h-100">
                <div class="fs-1 mb-3">🏬</div>
                <h4>Departments</h4>
                <p class="text-muted">View, add, edit and delete departments.</p>
                <a asp-controller="Departments" asp-action="Index" class="btn btn-primary mt-auto">Go to Departments</a>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card p-4 h-100">
                <div class="fs-1 mb-3">👥</div>
                <h4>Employees</h4>
                <p class="text-muted">View, add, edit and delete employees.</p>
                <a asp-controller="Employees" asp-action="Index" class="btn btn-primary mt-auto">Go to Employees</a>
            </div>
        </div>
    </div>
</div>
